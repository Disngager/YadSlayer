{
  "manifest_version": 3,
  "name": "YAdSlayer",
  "version": "1.0",
  "description": "Auto-skip YouTube ads. EMPYREAN LABS.",
  "permissions": ["scripting", "tabs"],
  "host_permissions": ["*://*.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YAdSlayer"
  }
}
